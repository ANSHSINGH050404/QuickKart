  },
  "devDependencies": {
    "@quickkart/eslint-config": "workspace:*",
    "@quickkart/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prisma": "^6.0.0",
    "typescript": "^5.7.0"
  }
}
